datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

model SiteContent {
  id        Int      @id @default(autoincrement())
  section   String   @unique
  data      String
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model AdminUser {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  lastLogin DateTime?
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  action     String
  section    String?
  adminEmail String
  ip         String?
  createdAt  DateTime @default(now())
}
