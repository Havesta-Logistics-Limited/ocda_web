datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

generator client {
  provider = "prisma-client-js"
}

model SiteContent {
  id        Int      @id @default(autoincrement())
  section   String   @unique
  data      String
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model AdminUser {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  lastLogin DateTime?
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  action     String
  section    String?
  adminEmail String
  ip         String?
  createdAt  DateTime @default(now())
}
